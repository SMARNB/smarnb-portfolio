# Copy to backend/.env and fill in. All values are optional for local dev.

# Generate a strong secret (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`)
SECRET_KEY=change-me-to-a-long-random-string

# Encryption-at-rest key for client/order PII. If blank it's derived from
# SECRET_KEY. For a dedicated key:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# ⚠️ Keep this safe and stable — if it changes, existing encrypted data can't be read.
ENCRYPTION_KEY=

# Admin (developer) login for /admin. CHANGE THE PASSWORD before deploying.
ADMIN_EMAIL=shahjee975@gmail.com
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Muhammad Ali Raza

# Login brute-force throttle (per IP)
LOGIN_MAX_ATTEMPTS=8
LOGIN_WINDOW_SECONDS=900

# Database. Default is a local SQLite file. For production use a persistent
# Postgres (free Neon works great) and install pg8000:
# DATABASE_URL=postgresql+pg8000://USER:PASSWORD@HOST/DBNAME

# Comma-separated allowed browser origins (use your real domain(s) in prod).
# Leave as * for local dev.
CORS_ORIGINS=*

# 7 days, in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080
